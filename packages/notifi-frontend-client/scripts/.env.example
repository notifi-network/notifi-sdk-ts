# ─── testTenantConfig.ts — required credentials ───────────────────────────────
# Copy this file to .env and fill in the values before running the script:
#   cp packages/notifi-frontend-client/scripts/.env.example \
#      packages/notifi-frontend-client/scripts/.env
#
# Usage:
#   npx tsx packages/notifi-frontend-client/scripts/testTenantConfig.ts

# Notifi tenant ID (e.g. found in Admin Portal → Settings)
TENANT_ID=

# Subscription Card ID to test against
CARD_ID=

# Tenant service account credentials (Admin Portal → Service Accounts)
TENANT_SID=
TENANT_SECRET=
